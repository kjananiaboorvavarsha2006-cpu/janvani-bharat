# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Table
DYNAMODB_TABLE_NAME=schemes

# Server Configuration
PORT=3001

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual AWS credentials
# 3. Ensure your AWS account has permissions for:
#    - Bedrock (Nova Lite model)
#    - Translate
#    - Polly
#    - Transcribe
#    - DynamoDB
# 4. Create a DynamoDB table named 'schemes' with primary key 'schemeId' (String)
