# AWS Configuration
# Get these from AWS Console → IAM → Users → Security Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Configuration
DYNAMODB_TABLE_NAME=schemes

# Server Configuration
PORT=3001

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Get AWS credentials:
#    - Go to AWS Console → IAM → Users
#    - Create new user or select existing
#    - Create access key
#    - Copy Access Key ID and Secret Access Key
#
# 3. Enable required AWS services:
#    - Amazon Bedrock (Nova Lite model)
#    - Amazon Translate
#    - Amazon Polly
#    - Amazon Transcribe
#    - Amazon DynamoDB
#
# 4. Create DynamoDB table:
#    npm run setup:db
#
# 5. Start the server:
#    npm run dev
#
# For detailed setup instructions, see AWS_SETUP_GUIDE.md
